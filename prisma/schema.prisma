// Prisma Schema - Sistem Informasi SD IT Iqra 2 Kota Bengkulu
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// ============================================================
// MODUL AUTENTIKASI & USER MANAGEMENT
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN_CMS
  ADMIN_PPDB
  KEPALA_SEKOLAH
  KARYAWAN // Guru dan Staf
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(KARYAWAN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi
  employee       Employee?
  posts          Post[]
  pages          Page[]
  uploadedMedia  Media[]

  @@map("users")
}

// ============================================================
// MODUL CMS (PROFIL SEKOLAH)
// ============================================================

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts Post[]

  @@map("categories")
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  content     String     // Rich text / HTML
  coverImage  String?    // Path atau URL gambar
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?

  authorId    String
  author      User       @relation(fields: [authorId], references: [id])

  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("posts")
}

model Page {
  id        String     @id @default(cuid())
  title     String
  slug      String     @unique
  content   String     // Rich text / HTML
  status    PostStatus @default(DRAFT)
  sortOrder Int        @default(0)

  authorId  String
  author    User       @relation(fields: [authorId], references: [id])

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("pages")
}

model Media {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  path        String
  url         String
  mimeType    String
  size        Int      // Ukuran file dalam bytes

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  createdAt   DateTime @default(now())

  @@map("media")
}

// ============================================================
// MODUL PPDB (PENERIMAAN SISWA BARU)
// ============================================================

// Status registrasi mengikuti alur PPDB lengkap sekolah
enum RegistrationStatus {
  PENDING_PAYMENT        // Akun dibuat, menunggu pembayaran
  PAYMENT_UPLOADED       // Bukti transfer diupload, menunggu verifikasi admin
  PAYMENT_VERIFIED       // Pembayaran diverifikasi, orang tua bisa isi formulir
  FORM_SUBMITTED         // Formulir & semua berkas sudah disubmit orang tua
  ADMIN_REVIEW           // Admin sedang melakukan seleksi administrasi
  ADMIN_PASSED           // Lulus seleksi administrasi
  CLINIC_LETTER_UPLOADED // Surat keterangan dari IMC sudah diupload
  OBSERVATION_SCHEDULED  // Orang tua sudah memilih jadwal observasi
  OBSERVATION_DONE       // Observasi sudah dilaksanakan, menunggu keputusan
  ACCEPTED               // Calon siswa diterima
  REJECTED               // Ditolak (bisa terjadi di tahap manapun)
}

enum Gender {
  L // Laki-laki
  P // Perempuan
}

// Model orang tua / wali pendaftar (terpisah dari model User admin)
model Parent {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations Registration[]

  @@map("parents")
}

// Tahun ajaran — mengatur kuota, biaya pendaftaran, periode, dan relasi ke kelas & slot observasi
model AcademicYear {
  id                String   @id @default(cuid())
  name              String   @unique // Contoh: "2026/2027"
  registrationStart DateTime
  registrationEnd   DateTime
  quota             Int      @default(0)
  registrationFee   Int      @default(300000) // Biaya pendaftaran dalam rupiah
  isActive          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  registrations    Registration[]
  observationSlots ObservationSlot[]
  classrooms       Classroom[]

  @@map("academic_years")
}

// Registrasi pendaftaran siswa baru — model utama PPDB
model Registration {
  id             String             @id @default(cuid())
  registrationNo String             @unique // Auto-generated: PPDB-26-XXXX

  // ── Relasi Utama ──
  academicYearId String
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id])
  parentId       String
  parent         Parent            @relation(fields: [parentId], references: [id])
  status         RegistrationStatus @default(PENDING_PAYMENT)

  // ── Tahap 1: Pembayaran Rp 300.000 ──
  paymentProof      String?   // URL Cloudinary bukti transfer
  paymentNote       String?   // Catatan dari orang tua saat upload bukti
  paymentVerifiedAt DateTime?
  paymentVerifiedBy String?   // ID admin yang memverifikasi

  // ── Tahap 2: Biodata Calon Siswa ──
  studentName      String?
  nickName         String?    // Nama panggilan
  gender           Gender?
  birthPlace       String?
  birthDate        DateTime?
  nisn             String?    // Nomor Induk Siswa Nasional (opsional)
  religion         String?
  address          String?    // Alamat lengkap siswa
  transport        String?    // Alat transportasi ke sekolah
  siblingCount     Int?       // Jumlah saudara kandung
  hobby            String?
  aspiration       String?    // Cita-cita
  hasSpecialNeeds  Boolean    @default(false)
  specialNeedsDesc String?    // Keterangan kebutuhan khusus (jika ada)

  // ── Tahap 2: Biodata Ayah ──
  fatherName    String?
  fatherNik     String?
  fatherJob     String?
  fatherIncome  String?  // Range penghasilan, contoh: "3000000-5000000"
  fatherPhone   String?
  fatherAddress String?

  // ── Tahap 2: Biodata Ibu ──
  motherName    String?
  motherNik     String?
  motherJob     String?
  motherIncome  String?
  motherPhone   String?
  motherAddress String?

  // ── Tahap 2: Biodata Wali (opsional, diisi jika bukan ayah/ibu) ──
  guardianName     String?
  guardianNik      String?
  guardianJob      String?
  guardianIncome   String?
  guardianPhone    String?
  guardianRelation String?  // Hubungan dengan siswa, contoh: "Kakak", "Paman"

  // ── Tahap 3: Upload Berkas ──
  docPhoto         String?  // Pasfoto 3x4 warna (URL Cloudinary)
  docTkCert        String?  // Surat keterangan TK/PAUD asal
  docBirthCert     String?  // Scan akte kelahiran
  docKartuKeluarga String?  // Scan kartu keluarga
  docKtpFather     String?  // Scan KTP ayah
  docKtpMother     String?  // Scan KTP ibu

  formSubmittedAt  DateTime? // Waktu submit formulir akhir

  // ── Tahap 4: Seleksi Administrasi ──
  adminNote       String?   // Catatan admin saat review
  adminReviewedAt DateTime?
  adminReviewedBy String?   // ID admin yang mereview

  // ── Tahap 5: Pemeriksaan Klinik IMC ──
  clinicReferralUrl String?  // URL PDF surat pengantar klinik (di-generate sistem)
  clinicReferralNo  String?  // Nomor surat pengantar yang di-generate
  docClinicCert     String?  // URL surat keterangan kesehatan dari IMC (diupload ortu)
  clinicCertUploadedAt DateTime?

  // ── Tahap 6: Observasi ──
  observationSlotId String?
  observationSlot   ObservationSlot? @relation(fields: [observationSlotId], references: [id])
  observationNote   String?   // Catatan hasil observasi dari admin
  observationResult String?   // "PASSED" atau "FAILED"
  observedAt        DateTime?

  // ── Tahap 7: Penetapan Kelas ──
  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id])

  // ── Status Penolakan ──
  rejectReason String? // Alasan penolakan (diisi saat status = REJECTED)
  rejectedAt   DateTime?
  rejectedBy   String?  // ID admin

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("registrations")
}

// Slot jadwal observasi — dikelola admin, dipilih oleh orang tua
model ObservationSlot {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  startTime String   // Contoh: "08:00"
  endTime   String   // Contoh: "10:00"
  quota     Int      @default(10)
  isActive  Boolean  @default(true)
  note      String?  // Catatan/instruksi untuk orang tua (opsional)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("observation_slots")
}

// Kelas paralel — dikelola admin, untuk assign siswa diterima
model Classroom {
  id          String @id @default(cuid())
  name        String // Contoh: "1A", "1B", "1C", "1D"
  grade       Int    @default(1)
  maxStudents Int    @default(30)
  homeroomTeacher String? // Nama wali kelas (opsional, bisa diisi nanti)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("classrooms")
}

// ============================================================
// MODUL KEHADIRAN (ABSENSI GURU & KARYAWAN)
// ============================================================

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  RESIGNED
}

model Employee {
  id          String         @id @default(cuid())
  nip         String?        @unique // Nomor Induk Pegawai
  position    String         // Jabatan / Posisi
  department  String?        // Divisi
  joinDate    DateTime
  status      EmployeeStatus @default(ACTIVE)
  phone       String?
  address     String?
  faceEmbedding String?      // JSON string face embedding untuk verifikasi (opsional server-side backup)

  // Relasi ke User (untuk login)
  userId      String         @unique
  user        User           @relation(fields: [userId], references: [id])

  attendanceLogs AttendanceLog[]
  leaveRequests  LeaveRequest[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("employees")
}

enum AttendanceType {
  HADIR
  IZIN
  SAKIT
  ALPHA  // Tanpa keterangan
  LIBUR
  CUTI
  DINAS
}

model AttendanceLog {
  id              String         @id @default(cuid())
  date            DateTime       @db.Date
  clockIn         DateTime?
  clockOut        DateTime?
  type            AttendanceType @default(HADIR)
  note            String?

  // GPS Data
  clockInLat      Float?         // Latitude saat clock in
  clockInLng      Float?         // Longitude saat clock in
  clockOutLat     Float?         // Latitude saat clock out
  clockOutLng     Float?         // Longitude saat clock out
  clockInDistance  Float?         // Jarak dari sekolah (meter) saat clock in
  clockOutDistance Float?         // Jarak dari sekolah (meter) saat clock out

  // Anti-Fake GPS
  isMockGps       Boolean        @default(false) // Flag fake GPS terdeteksi

  // Face Recognition
  faceConfidence  Float?         // Confidence score 0-1
  clockInSelfie   String?        // URL/path foto selfie clock in
  clockOutSelfie  String?        // URL/path foto selfie clock out

  // Status
  isLate          Boolean        @default(false) // Terlambat berdasarkan threshold
  anomalyFlag     String?        // "OUT_OF_RADIUS" | "MOCK_GPS" | "LOW_FACE_CONFIDENCE" | null
  anomalyNote     String?        // Catatan anomali tambahan

  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([employeeId, date]) // Satu karyawan satu log per hari
  @@map("attendance_logs")
}

// ── Konfigurasi Geofencing & Jam Kerja ──
model AttendanceConfig {
  id              String   @id @default(cuid())
  schoolName      String   @default("SDIT Iqra 2 Kota Bengkulu")
  schoolLatitude  Float    @default(-3.7928)   // Koordinat default Bengkulu
  schoolLongitude Float    @default(102.2608)
  radiusMeters    Int      @default(100)        // Radius geofencing (meter)
  clockInStart    String   @default("06:30")    // Mulai bisa clock in
  clockInEnd      String   @default("08:00")    // Batas akhir clock in
  clockOutStart   String   @default("14:00")    // Mulai bisa clock out
  clockOutEnd     String   @default("17:00")    // Batas akhir clock out
  lateThreshold   String   @default("07:15")    // Lewat ini = terlambat
  minFaceConfidence Float  @default(0.75)       // Minimum confidence face recognition
  allowMockGps    Boolean  @default(false)       // Izinkan mock GPS (untuk testing)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("attendance_configs")
}

// ── Hari Libur ──
enum HolidayType {
  NATIONAL     // Hari libur nasional Indonesia
  SCHOOL       // Libur sekolah (liburan semester, dsb)
}

model Holiday {
  id          String      @id @default(cuid())
  date        DateTime    @db.Date
  name        String      // "Hari Raya Idul Fitri", "Libur Semester 1"
  type        HolidayType @default(NATIONAL)
  isRecurring Boolean     @default(false) // Apakah berulang tiap tahun (misal: Tahun Baru)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([date, name]) // Tidak boleh duplikat tanggal+nama
  @@map("holidays")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  IZIN     // Izin biasa
  SAKIT    // Sakit (dengan surat dokter)
  CUTI     // Cuti tahunan
  DINAS    // Perjalanan dinas
}

model LeaveRequest {
  id           String      @id @default(cuid())
  type         LeaveType
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  reason       String
  attachment   String?     // URL bukti/surat keterangan di Cloudinary
  status       LeaveStatus @default(PENDING)
  approverNote String?     // Catatan dari approver
  approvedBy   String?     // ID admin yang approve/reject
  approvedAt   DateTime?   // Waktu approve/reject

  employeeId   String
  employee     Employee    @relation(fields: [employeeId], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("leave_requests")
}

// ============================================================
// MODUL PENGATURAN SITUS (SITE SETTINGS)
// ============================================================

// Menyimpan konfigurasi global situs sebagai key-value.
// Contoh key:
//   site_name, site_tagline, site_logo, site_favicon
//   contact_email, contact_phone, contact_address, contact_maps_embed
//   hero_title, hero_subtitle, hero_cta_primary_text, hero_cta_primary_url
//   hero_cta_secondary_text, hero_cta_secondary_url
//   stats          → JSON: [{ icon, value, label }, ...]
//   features       → JSON: [{ icon, title, desc }, ...]
//   social_facebook, social_instagram, social_youtube
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text // Bisa berisi teks panjang atau JSON
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ============================================================
// MODUL MENU NAVIGASI
// ============================================================

// Item menu navigasi publik (header dan/atau footer)
model MenuItem {
  id          String   @id @default(cuid())
  label       String                      // Teks tampil: "Tentang Kami"
  url         String                      // Path atau URL eksternal: "/tentang"
  order       Int      @default(0)        // Urutan tampil (makin kecil makin depan)
  isActive    Boolean  @default(true)     // Tampilkan atau sembunyikan
  openInNewTab Boolean @default(false)    // Buka di tab baru (_blank)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("menu_items")
}
